{
  "name": "apexflow",
  "displayName": "ApexFlow",
  "description": "Full ApexFlow experience inside VS Code — architecture map, Analyze Flow call graphs, and Trace Parents for Salesforce Apex/LWC/Java projects, backed by direct Node.js filesystem access instead of the browser's sandboxed File System Access API.",
  "version": "0.2.0",
  "publisher": "apexflow",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/rexcclui/XTools.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./src/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "apexflowFull.open",
        "title": "ApexFlow: Open Diagram"
      },
      {
        "command": "apexflowTraceParents.traceFromFile",
        "title": "ApexFlow: Trace Parents (this component)"
      },
      {
        "command": "apexflowTraceParents.traceSelection",
        "title": "ApexFlow: Trace Parents (selected name)"
      },
      {
        "command": "apexflowTraceParents.traceByName",
        "title": "ApexFlow: Trace Parents…"
      },
      {
        "command": "apexflowTraceParents.refresh",
        "title": "ApexFlow: Rescan Workspace Files",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "apexflowFull.open",
          "when": "resourceExtname == .js || resourceExtname == .html || resourceExtname == .cls || resourceExtname == .java",
          "group": "apexflow@1"
        },
        {
          "command": "apexflowTraceParents.traceFromFile",
          "when": "resourceExtname == .js || resourceExtname == .html",
          "group": "apexflow@2"
        }
      ],
      "editor/context": [
        {
          "command": "apexflowFull.open",
          "when": "resourceExtname == .js || resourceExtname == .html || resourceExtname == .cls || resourceExtname == .java",
          "group": "apexflow@1"
        },
        {
          "command": "apexflowTraceParents.traceSelection",
          "when": "editorHasSelection && (resourceExtname == .js || resourceExtname == .html)",
          "group": "apexflow@2"
        },
        {
          "command": "apexflowTraceParents.traceFromFile",
          "when": "!editorHasSelection && (resourceExtname == .js || resourceExtname == .html)",
          "group": "apexflow@2"
        }
      ],
      "view/title": [
        {
          "command": "apexflowTraceParents.refresh",
          "when": "view == apexflowTraceParentsView",
          "group": "navigation"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "apexflowTraceParentsView",
          "name": "ApexFlow: Trace Parents (quick view)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "apexflowTraceParentsView",
        "contents": "For the full architecture map, Analyze Flow, and every diagram feature, run **ApexFlow: Open Diagram** from the Command Palette.\n[Open full diagram](command:apexflowFull.open)\n\nOr, for a quick lightweight lookup right here: right-click a `.js`/`.html` LWC file and choose **ApexFlow: Trace Parents (this component)**.\n[Trace by name](command:apexflowTraceParents.traceByName)"
      }
    ]
  }
}
