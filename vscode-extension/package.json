{
  "name": "codegraph-apex-lwc",
  "displayName": "CodeGraph Apex/LWC",
  "description": "See how your Salesforce Apex, LWC, and Java code connects — interactive architecture map, per-class call-flow diagrams, and parent tracing, right inside VS Code.",
  "version": "0.2.4",
  "publisher": "xer100001",
  "repository": {
    "type": "git",
    "url": "https://github.com/rexcclui/XTools.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./src/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "apexflowFull.open",
        "title": "CodeGraph Apex/LWC: Open Diagram"
      },
      {
        "command": "apexflowFull.addFile",
        "title": "CodeGraph Apex/LWC: Add to Diagram"
      },
      {
        "command": "apexflowTraceParents.traceFromFile",
        "title": "CodeGraph Apex/LWC: Trace Parents (this component)"
      },
      {
        "command": "apexflowTraceParents.traceSelection",
        "title": "CodeGraph Apex/LWC: Trace Parents (selected name)"
      },
      {
        "command": "apexflowTraceParents.traceByName",
        "title": "CodeGraph Apex/LWC: Trace Parents…"
      },
      {
        "command": "apexflowTraceParents.refresh",
        "title": "CodeGraph Apex/LWC: Rescan Workspace Files",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "apexflowFull.open",
          "when": "resourceExtname == .js || resourceExtname == .html || resourceExtname == .cls || resourceExtname == .java",
          "group": "apexflow@1"
        },
        {
          "command": "apexflowFull.addFile",
          "when": "resourceExtname == .js || resourceExtname == .html || resourceExtname == .cls || resourceExtname == .java",
          "group": "apexflow@2"
        }
      ],
      "editor/context": [
        {
          "command": "apexflowFull.open",
          "when": "resourceExtname == .js || resourceExtname == .html || resourceExtname == .cls || resourceExtname == .java",
          "group": "apexflow@1"
        },
        {
          "command": "apexflowFull.addFile",
          "when": "resourceExtname == .js || resourceExtname == .html || resourceExtname == .cls || resourceExtname == .java",
          "group": "apexflow@2"
        },
        {
          "command": "apexflowTraceParents.traceSelection",
          "when": "editorHasSelection && (resourceExtname == .js || resourceExtname == .html)",
          "group": "apexflow@3"
        },
        {
          "command": "apexflowTraceParents.traceFromFile",
          "when": "!editorHasSelection && (resourceExtname == .js || resourceExtname == .html)",
          "group": "apexflow@3"
        }
      ],
      "view/title": [
        {
          "command": "apexflowTraceParents.refresh",
          "when": "view == apexflowTraceParentsView",
          "group": "navigation"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "apexflowTraceParentsView",
          "name": "CodeGraph Apex/LWC: Trace Parents (quick view)",
          "icon": "media/trace-parents-dark.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "apexflowTraceParentsView",
        "contents": "For the full architecture map, Analyze Flow, and every diagram feature, run **CodeGraph Apex/LWC: Open Diagram** from the Command Palette.\n[Open full diagram](command:apexflowFull.open)\n\nOr, for a quick lightweight lookup right here: right-click inside an open `.js`/`.html` file (with nothing selected) and choose **CodeGraph Apex/LWC: Trace Parents (this component)**.\n[Trace by name](command:apexflowTraceParents.traceByName)"
      }
    ]
  }
}
