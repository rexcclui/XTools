{
  // https://apexflow.trendx.uk
  "name": "apexflow",
  "compatibility_date": "2026-04-30",
  "main": "src/index.js",
  "build": { "command": "npm run build" },
  "assets": {
    "directory": "dist",
    "binding": "ASSETS",
    "html_handling": "none",
    "run_worker_first": true
  },
  "kv_namespaces": [
    { "binding": "VISITS", "id": "81c54a172328490484ef906f64ff2677" }
  ]
}
